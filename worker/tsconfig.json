{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "../src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
